# Required — get your key at https://openrouter.ai
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Required for web search (Constructor + Evaluator tool) — get your key at https://tavily.com
TAVILY_API_KEY=your-tavily-api-key-here

# Optional — override to use any OpenAI-compatible endpoint
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Models — any OpenRouter model string works for either role
# primary:   used by Constructor, Critique, Evaluator, and Resolver
# preflight: used by parsing, domain-standard inference, and contrary generation
GAUNTLET_PRIMARY_MODEL=anthropic/claude-opus-4-6
GAUNTLET_PREFLIGHT_MODEL=anthropic/claude-haiku-4-5

# Global runtime mode: base, clinical, or financial
GAUNTLET_MODE=base

# Server
GAUNTLET_HOST=0.0.0.0
GAUNTLET_PORT=8000
GAUNTLET_RELOAD=false
